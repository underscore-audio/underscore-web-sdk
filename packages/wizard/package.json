{
  "name": "@underscore-audio/wizard",
  "version": "0.1.2",
  "type": "module",
  "description": "Install and configure Underscore in an existing web project in under five minutes",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "underscore-wizard": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "execa": "^9.6.1",
    "magicast": "^0.5.2",
    "picocolors": "^1.1.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "memfs": "^4.57.2",
    "msw": "^2.1.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^7.0.0",
    "vitest": "^1.2.0"
  },
  "keywords": [
    "underscore",
    "audio",
    "cli",
    "wizard",
    "installer"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/underscore-audio/underscore-web-sdk.git",
    "directory": "packages/wizard"
  },
  "homepage": "https://underscore.audio/docs/web-sdk/wizard",
  "bugs": {
    "url": "https://github.com/underscore-audio/underscore-web-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
