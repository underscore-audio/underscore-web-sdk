# Browser (Vite; values are bundled into the client)
VITE_UNDERSCORE_PUBLISHABLE_KEY=us_pub_your_publishable_key_here

# Optional: Underscore API host. Defaults to https://underscore.audio
# VITE_UNDERSCORE_HOST=http://localhost:3333

# Optional: Default public composition ID to load on startup
# VITE_UNDERSCORE_COMPOSITION_ID=cmp_abc123

# Optional: Local backend proxy URL. Defaults to http://localhost:8787
# VITE_PROXY_URL=http://localhost:8787

# Backend proxy (Node only; never expose this to browser code)
UNDERSCORE_SECRET_KEY=us_sec_your_secret_key_here

# Optional: API host used by the backend proxy
# UNDERSCORE_HOST=http://localhost:3333

# Optional: Backend proxy port
# PORT=8787
